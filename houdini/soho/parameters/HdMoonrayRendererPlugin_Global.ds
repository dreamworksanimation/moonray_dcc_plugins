            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_subsurface_per_path_4bcn"
            label   "Max Subsurface Per Path"
            type    integer
            default { "1" }
            help    "The maximum ray depth (number of \"bounces\") to allow subsurface scattering. For ray depths beyond this limit Lambertian diffuse is used to approximate subsurface scattering."
            disablewhen "{ xn__moonraysceneVariablemax_subsurface_per_path_control_5ocn == block } { xn__moonraysceneVariablemax_subsurface_per_path_control_5ocn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablerussian_roulette_threshold_control_1tcn"
            label   "moonray:sceneVariable:russian_roulette_threshold"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablerussian_roulette_threshold_0gcn"
            label   "Russian Roulette Threshold"
            type    float
            default { "0.0375" }
            help    "The Russian roulette threshold specifies the point at which point Russian roulette is evaluated for direct light sampling and BSDF continuation. The unit is luminance of the radiance."
            disablewhen "{ xn__moonraysceneVariablerussian_roulette_threshold_control_1tcn == block } { xn__moonraysceneVariablerussian_roulette_threshold_control_1tcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariabletransparency_threshold_control_jncn"
            label   "moonray:sceneVariable:transparency_threshold"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariabletransparency_threshold_i9bn"
            label   "Transparency Threshold"
            type    float
            default { "1" }
            help    "The transparency threshold defines the point at which the accumulated opacity can be considered opaque, skipping the generation of new transparency rays."
            disablewhen "{ xn__moonraysceneVariabletransparency_threshold_control_jncn == block } { xn__moonraysceneVariabletransparency_threshold_control_jncn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablepresence_threshold_control_0gcn"
            label   "moonray:sceneVariable:presence_threshold"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablepresence_threshold_z2bn"
            label   "Presence Threshold"
            type    float
            default { "0.999" }
            help    "The presence threshold defines the point at which the accumulated presence can be considered opaque, skipping the generation of presence continuation rays."
            disablewhen "{ xn__moonraysceneVariablepresence_threshold_control_0gcn == block } { xn__moonraysceneVariablepresence_threshold_control_0gcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablepresence_quality_control_rdcn"
            label   "moonray:sceneVariable:presence_quality"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablepresence_quality_qzbn"
            label   "Presence Quality"
            type    float
            default { "0.75" }
            help    "The presence quality defines the threshold for path throughput after which presence sampling becomes stochastic. This is similar to russian roulette.  A value of 1.0 means never use stochastic sampling (highest quality).  A value of 0.0 means always use stochastic sampling (faster, but may be noisy).  Values between 0.0 and 1.0 will generally be a good trade-off in speed vs. quality when multiple layers of presence are involved."
            disablewhen "{ xn__moonraysceneVariablepresence_quality_control_rdcn == block } { xn__moonraysceneVariablepresence_quality_control_rdcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablelock_frame_noise_control_rdcn"
            label   "moonray:sceneVariable:lock_frame_noise"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablelock_frame_noise_qzbn"
            label   "Lock Frame Noise"
            type    toggle
            default { "0" }
            help    "By default, the random number generators are seeded by considering the frame number. However, if lock_frame_noise is true, the same seed values are used for each frame, which is typically undesirable."
            disablewhen "{ xn__moonraysceneVariablelock_frame_noise_control_rdcn == block } { xn__moonraysceneVariablelock_frame_noise_control_rdcn == none }"
            parmtag { "usdvaluetype" "bool" }
        }
    }

    group {
        name    "folder7"
        label   "Volumes"

        parm {
            name    "xn__moonraysceneVariablemax_volume_depth_control_rdcn"
            label   "moonray:sceneVariable:max_volume_depth"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_volume_depth_qzbn"
            label   "Max Volume Depth"
            type    integer
            default { "1" }
            help    "The maximum ray depth (number of \"bounces\") for volume event types. Volumes are ignored after this depth has been reached. Reducing this can improve performance at the cost of biasing the rendered image. "
            disablewhen "{ xn__moonraysceneVariablemax_volume_depth_control_rdcn == block } { xn__moonraysceneVariablemax_volume_depth_control_rdcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_quality_control_i9bn"
            label   "moonray:sceneVariable:volume_quality"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_quality_hwbn"
            label   "Volume Quality"
            type    float
            default { "0.5" }
            help    "Controls the overall quality of volume rendering. The higher number gives better volume shape detail and more accurate scattering integration result."
            disablewhen "{ xn__moonraysceneVariablevolume_quality_control_i9bn == block } { xn__moonraysceneVariablevolume_quality_control_i9bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_shadow_quality_control_wlcn"
            label   "moonray:sceneVariable:volume_shadow_quality"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_shadow_quality_v7bn"
            label   "Volume Shadow Quality"
            type    float
            default { "1" }
            help    "Controls the quality of volume shadow (transmittance). The higher number gives more accurate volume shadow."
            disablewhen "{ xn__moonraysceneVariablevolume_shadow_quality_control_wlcn == block } { xn__moonraysceneVariablevolume_shadow_quality_control_wlcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_illumination_samples_control_ovcn"
            label   "moonray:sceneVariable:volume_illumination_samples"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_illumination_samples_nicn"
            label   "Volume Illumination Samples"
            type    integer
            default { "4" }
            help    "Sample number along the ray when computing volume scattering radiance towards the eye. Set to 0 to turn off volume lighting completely."
            disablewhen "{ xn__moonraysceneVariablevolume_illumination_samples_control_ovcn == block } { xn__moonraysceneVariablevolume_illumination_samples_control_ovcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_opacity_threshold_control_sqcn"
            label   "moonray:sceneVariable:volume_opacity_threshold"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_opacity_threshold_rdcn"
            label   "Volume Opacity Threshold"
            type    float
            default { "0.995" }
            help    "As a ray travels through volumes, it will accumulate opacity. When the value exceeds the volume opacity threshold, the renderer will stop further volume integration along this ray."
            disablewhen "{ xn__moonraysceneVariablevolume_opacity_threshold_control_sqcn == block } { xn__moonraysceneVariablevolume_opacity_threshold_control_sqcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_overlap_mode_control_nicn"
            label   "moonray:sceneVariable:volume_overlap_mode"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_overlap_mode_m4bn"
            label   "Volume Overlap Mode"
            type    string
            default { "sum" }
            help    "Selects how to handle contributions from overlapping volumes:\n		sum: add contributions from all volumes\n		max: only consider maximum volume based on extinction\n		rnd: randomly choose one value weighted by extinction\n		Warning: light linking does not work correctly in sum mode."
            disablewhen "{ xn__moonraysceneVariablevolume_overlap_mode_control_nicn == block } { xn__moonraysceneVariablevolume_overlap_mode_control_nicn == none }"
            menu {
                "sum"   "Sum"
                "max"   "Max"
                "rnd"   "Rnd"
            }
            parmtag { "usdvaluetype" "token" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_attenuation_factor_control_fscn"
            label   "moonray:sceneVariable:volume_attenuation_factor"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_attenuation_factor_efcn"
            label   "Volume Attenuation Factor"
            type    float
            default { "0.65" }
            help    "Controls how volume attenuation gets exponentially scaled down when rendering multiple scattering volumes. Dialing down the value generally results in more translucent look. This variable is only effective when \"max volume depth\" is greater than 1"
            disablewhen "{ xn__moonraysceneVariablevolume_attenuation_factor_control_fscn == block } { xn__moonraysceneVariablevolume_attenuation_factor_control_fscn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_contribution_factor_control_1tcn"
            label   "moonray:sceneVariable:volume_contribution_factor"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_contribution_factor_0gcn"
            label   "Volume Contribution Factor"
            type    float
            default { "0.65" }
            help    "Controls how scattering contribution gets exponentially scaled down when rendering multiple scattering volumes. Dialing down the value generally results in a darker volume scattering look. This variable is only effective when \"max volume depth\" is greater than 1"
            disablewhen "{ xn__moonraysceneVariablevolume_contribution_factor_control_1tcn == block } { xn__moonraysceneVariablevolume_contribution_factor_control_1tcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablevolume_phase_attenuation_factor_control_61cn"
            label   "moonray:sceneVariable:volume_phase_attenuation_factor"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
