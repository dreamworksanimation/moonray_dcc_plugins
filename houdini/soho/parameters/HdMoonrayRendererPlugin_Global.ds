        parm {
            name    "xn__moonraysceneVariablemax_diffuse_depth_d1bn"
            label   "Max Diffuse Depth"
            type    integer
            default { "2" }
            help    "The maximum ray depth (number of \"bounces\") for diffuse event types. Reducing this can improve performance at the cost of biasing the rendered image. Note that this limit is also governed by the global \"max depth\" attribute."
            disablewhen "{ xn__moonraysceneVariablemax_diffuse_depth_control_efcn == block } { xn__moonraysceneVariablemax_diffuse_depth_control_efcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
