            label   "Max Glossy Depth"
            type    integer
            default { "2" }
            help    "The maximum ray depth (number of \"bounces\") for glossy event types. Reducing this can improve performance at the cost of biasing the rendered image. Note that this limit is also governed by the global \"max depth\" attribute."
            disablewhen "{ xn__moonraysceneVariablemax_glossy_depth_control_rdcn == block } { xn__moonraysceneVariablemax_glossy_depth_control_rdcn == none }"
            range   { 0 10 }
