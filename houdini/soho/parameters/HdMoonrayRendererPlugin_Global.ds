    parm {
        name    "xn__moonraysceneVariablebatch_tile_order_qzbn"
        label   "Batch Tile Order"
        type    string
        default { "morton" }
        help    "Specifies the order in which tiles (as areas of 8x8 pixels) are prioritized for batch rendering, which determines which areas of the image are rendered first. The ordering is not guaranteed: the strict sequence of tile starting and completion for any pass is nondeterministic due to thread scheduling."
        disablewhen "{ xn__moonraysceneVariablebatch_tile_order_control_rdcn == block } { xn__moonraysceneVariablebatch_tile_order_control_rdcn == none }"
        menu {
            "top"               "Top"
            "bottom"            "Bottom"
            "left"              "Left"
            "right"             "Right"
            "morton"            "Morton"
            "random"            "Random"
            "spiral square"     "Spiral Square"
            "spiral rect"       "Spiral Rect"
            "morton shiftflip"  "Morton Shiftflip"
        }
        parmtag { "usdvaluetype" "token" }
    }
