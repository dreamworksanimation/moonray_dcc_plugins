            name    "xn__moonraysceneVariablesample_clamping_depth_v7bn"
            label   "Sample Clamping Depth"
            type    integer
            default { "1" }
            help    "Clamp sample values only after the given non-specular ray depth."
            disablewhen "{ xn__moonraysceneVariablesample_clamping_depth_control_wlcn == block } { xn__moonraysceneVariablesample_clamping_depth_control_wlcn == none }"
