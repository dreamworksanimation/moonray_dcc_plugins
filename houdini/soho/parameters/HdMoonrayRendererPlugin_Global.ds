            label   "Max Mirror Depth"
            type    integer
            default { "3" }
            help    "The maximum ray depth (number of \"bounces\") for mirror event types. Reducing this can improve performance at the cost of biasing the rendered image. Note that this limit is also governed by the global \"max depth\" attribute."
            disablewhen "{ xn__moonraysceneVariablemax_mirror_depth_control_rdcn == block } { xn__moonraysceneVariablemax_mirror_depth_control_rdcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
