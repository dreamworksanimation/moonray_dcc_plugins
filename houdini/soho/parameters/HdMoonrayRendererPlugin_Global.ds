            type    integer
            default { "-1" }
            help    "Specifies the port number for the debug console. When the debug console functionalities are enabled, you can use a telnet connection to send commands and control rendering behavior for debugging purposes.\n- A value of -1 disables all debug console functionality.\n- A positive value specifies a specific port number.\n- If you set the port number to 0, the kernel will find an available port for you and display the port number to stderr."
            disablewhen "{ xn__moonraysceneVariabledebug_console_control_v7bn == block } { xn__moonraysceneVariabledebug_console_control_v7bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
