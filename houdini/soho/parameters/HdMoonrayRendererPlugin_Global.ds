    parm {
        name    "xn__moonraysceneVariablemin_adaptive_samples_85bn"
        label   "Min Adaptive Samples"
        type    integer
        default { "16" }
        help    "This is the minimum number of samples taken per pixel before enabling adaptive sampling. A larger number of samples may prevent the adaptive sampler from prematurely identifying an area as converged but may incur a longer running time."
        disablewhen "{ xn__moonraysceneVariablemin_adaptive_samples_control_9jcn == block } { xn__moonraysceneVariablemin_adaptive_samples_control_9jcn == none }"
        range   { 0 10 }
        parmtag { "usdvaluetype" "int" }
    }
    parm {
        name    "xn__moonraysceneVariablemax_adaptive_samples_control_9jcn"
        label   "moonray:sceneVariable:max_adaptive_samples"
        type    string
        default { "none" }
        menujoin {
            "set"           "![BUTTONS_set_or_create]Set or Create"
            "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
            "add"           "![BUTTONS_set_add]Add if Exists"
            "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
