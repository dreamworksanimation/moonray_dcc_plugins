        parm {
            name    "xn__moonraysceneVariablemax_depth_cobn"
            label   "Max Depth"
            type    integer
            default { "5" }
            help    "The maximum ray depth (number of \"bounces\") for diffuse|glossy|mirror event types. This can be thought of as the global depth limit. Reducing this can improve performance at the cost of biasing the rendered image."
            disablewhen "{ xn__moonraysceneVariablemax_depth_control_d1bn == block } { xn__moonraysceneVariablemax_depth_control_d1bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_diffuse_depth_control_efcn"
            label   "moonray:sceneVariable:max_diffuse_depth"
