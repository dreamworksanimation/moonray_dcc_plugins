                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_interval_m4bn"
            label   "Checkpoint Interval"
            type    float
            default { "15" }
            help    "Specifies the time interval, in minutes, between checkpoint file writes. The interval must be equal to or greater than 0.1 minutes."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_interval_control_nicn == block } { xn__moonraysceneVariablecheckpoint_interval_control_nicn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_quality_steps_control_sqcn"
            label   "moonray:sceneVariable:checkpoint_quality_steps"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_quality_steps_rdcn"
            label   "Checkpoint Quality Steps"
            type    integer
            default { "2" }
            help    "Specifies the number of quality steps, which refers to the internal sampling iteration count between checkpoint file writes. The value must be equal to or greater than 1. In the case of uniform sampling, this number of steps is equivalent to the pixel sampling steps for each pixel. For example, if you set quality steps to 2, a checkpoint file will be created every time each pixel's sample count exceeds 2, 4, 6, 8, 10, and so on. In the case of adaptive sampling, this number of steps is equivalent to the internal adaptive sampling iteration steps. A recommended number falls within the range of 1 to 3. For example, if you set the value to 2, a checkpoint file will be created after finishing every 2 adaptive sampling passes. A larger value will conduct more rendering passes before writing a file."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_quality_steps_control_sqcn == block } { xn__moonraysceneVariablecheckpoint_quality_steps_control_sqcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_time_cap_control_nicn"
            label   "moonray:sceneVariable:checkpoint_time_cap"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_time_cap_m4bn"
            label   "Checkpoint Time Cap"
            type    float
            default { "0" }
            help    "Determines when the render will finish based on the total render process time in minutes. If the value is exceeded, the render will finish after the next checkpoint write. If the value is set to 0, the time cap feature is disabled."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_time_cap_control_nicn == block } { xn__moonraysceneVariablecheckpoint_time_cap_control_nicn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_sample_cap_control_wlcn"
            label   "moonray:sceneVariable:checkpoint_sample_cap"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_sample_cap_v7bn"
            label   "Checkpoint Sample Cap"
            type    integer
            default { "0" }
            help    "Causes the render to finish based on the total pixel sample count. For example, if the value is 1024, the render will end after the next checkpoint write when each pixel exceeds 1024 samples. If the value is set to 0, the sample cap feature is disabled."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_sample_cap_control_wlcn == block } { xn__moonraysceneVariablecheckpoint_sample_cap_control_wlcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_overwrite_control_9jcn"
            label   "moonray:sceneVariable:checkpoint_overwrite"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_overwrite_85bn"
            label   "Checkpoint Overwrite"
            type    toggle
            default { "1" }
            help    "When set to true, the last checkpoint file will be overwritten when writing out the new checkpoint file. If set to false, the checkpoint filename will be appended with the total number of samples, which will result in the retention of all checkpoint files."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_overwrite_control_9jcn == block } { xn__moonraysceneVariablecheckpoint_overwrite_control_9jcn == none }"
            parmtag { "usdvaluetype" "bool" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_mode_control_4bcn"
            label   "moonray:sceneVariable:checkpoint_mode"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_mode_3xbn"
            label   "Checkpoint Mode"
            type    string
            default { "time" }
            help    "Allows you to choose whether checkpoint images are written based on time elapsed or on quality reached."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_mode_control_4bcn == block } { xn__moonraysceneVariablecheckpoint_mode_control_4bcn == none }"
            menu {
                "time"      "Time"
                "quality"   "Quality"
            }
            parmtag { "usdvaluetype" "token" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_start_sample_control_5ocn"
            label   "moonray:sceneVariable:checkpoint_start_sample"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_start_sample_4bcn"
            label   "Checkpoint Start Sample"
            type    integer
            default { "1" }
            help    "Specifies the samples per pixel (SPP). A checkpoint file is created when all pixels' SPP are greater than or equal to this number. A checkpoint file is created once this criterion is met."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_start_sample_control_5ocn == block } { xn__moonraysceneVariablecheckpoint_start_sample_control_5ocn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_bg_write_control_nicn"
            label   "moonray:sceneVariable:checkpoint_bg_write"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_bg_write_m4bn"
            label   "Checkpoint Bg Write"
            type    toggle
            default { "1" }
            help    "When set to true, checkpoint file writes occur in a background thread that runs concurrently with the MCRT threads. Otherwise, all MCRT threads must wait while the checkpoint file is written."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_bg_write_control_nicn == block } { xn__moonraysceneVariablecheckpoint_bg_write_control_nicn == none }"
            parmtag { "usdvaluetype" "bool" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_post_script_control_jncn"
            label   "moonray:sceneVariable:checkpoint_post_script"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_post_script_i9bn"
            label   "Checkpoint Post Script"
            type    string
            default { "" }
            help    "Specifies the filename of a Lua script that will be executed after every checkpoint file is written. The script will run concurrently with the ongoing MCRT threads. For more information, refer to the documentation for MoonRay-provided Lua variables accessible within the script."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_post_script_control_jncn == block } { xn__moonraysceneVariablecheckpoint_post_script_control_jncn == none }"
            parmtag { "usdvaluetype" "string" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_total_files_control_jncn"
            label   "moonray:sceneVariable:checkpoint_total_files"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_total_files_i9bn"
            label   "Checkpoint Total Files"
            type    integer
            default { "0" }
            help    "This variable specifies the total number of checkpoint files for the quality-based checkpoint mode. It serves as a substitute parameter for checkpoint_quality_steps. If the value is set to 0 (the default), the interval at which checkpoints are generated is controlled by the checkpoint_quality_steps variable. If the value is set to 1 or higher, the renderer will attempt to automatically generate a user-defined number of checkpoint files based on this value. This option takes into account the checkpoint_start_sample variable.\n\nIn some cases, the renderer may be unable to create the requested number of checkpoint_total_files due to limitations in the internal implementation or because the user has specified a value greater than 1 for the checkpoint_start_sample variable. However, in these cases, the renderer will attempt to generate the closest possible number of checkpoint files to the user-defined value."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_total_files_control_jncn == block } { xn__moonraysceneVariablecheckpoint_total_files_control_jncn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_max_bgcache_control_jncn"
            label   "moonray:sceneVariable:checkpoint_max_bgcache"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_max_bgcache_i9bn"
            label   "Checkpoint Max Bgcache"
            type    integer
            default { "2" }
            help    "Specifies the maximum number of queued checkpoint images the checkpoint-writing background thread can handle. The value of checkpoint_max_bgcache must be greater than or equal to 1. If the number of queued checkpoint images exceeds this limit, MCRT threads will be temporarily suspended while background images are written to make room in the queue. A larger value can support background writing even with short checkpoint intervals, but it may require more memory. A value of 2 is recommended for most cases."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_max_bgcache_control_jncn == block } { xn__moonraysceneVariablecheckpoint_max_bgcache_control_jncn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_max_snapshot_overhead_control_t3cn"
            label   "moonray:sceneVariable:checkpoint_max_snapshot_overhead"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_max_snapshot_overhead_sqcn"
            label   "Checkpoint Max Snapshot Overhead"
            type    float
            default { "0" }
            help    "Specifies the maximum fraction of the snapshot overhead threshold for an extra snapshot action in the event of an unexpected interruption by SIGINT. The value is expressed as a fraction. If the value is set to zero or a negative number, no extra snapshot action will be executed, and no checkpoint file will be generated if SIGINT is received."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_max_snapshot_overhead_control_t3cn == block } { xn__moonraysceneVariablecheckpoint_max_snapshot_overhead_control_t3cn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_snapshot_interval_control_bxcn"
            label   "moonray:sceneVariable:checkpoint_snapshot_interval"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecheckpoint_snapshot_interval_9jcn"
            label   "Checkpoint Snapshot Interval"
            type    float
            default { "0" }
            help    "Specifies the time interval, in minutes, allowed for a snapshot when a SIGINT is encountered. If the value is 0 or negative, the checkpoint_max_snapshot_overhead parameter is used instead."
            disablewhen "{ xn__moonraysceneVariablecheckpoint_snapshot_interval_control_bxcn == block } { xn__moonraysceneVariablecheckpoint_snapshot_interval_control_bxcn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
    }

