        parm {
            name    "xn__moonraysceneVariablebssrdf_samples_hwbn"
            label   "Bssrdf Samples"
            type    integer
            default { "2" }
            help    "The square root of the number of samples taken to evaluate BSSRDF (subsurface scattering) contributions on the primary intersection."
            disablewhen "{ xn__moonraysceneVariablebssrdf_samples_control_i9bn == block } { xn__moonraysceneVariablebssrdf_samples_control_i9bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_depth_control_d1bn"
            label   "moonray:sceneVariable:max_depth"
