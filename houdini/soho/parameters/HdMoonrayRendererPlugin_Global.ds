        parm {
            name    "xn__moonraysceneVariablemax_presence_depth_control_0gcn"
            label   "moonray:sceneVariable:max_presence_depth"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
