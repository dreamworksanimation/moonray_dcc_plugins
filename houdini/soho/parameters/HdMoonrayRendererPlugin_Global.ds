#include "$HFS/houdini/soho/parameters/CommonMacros.ds"
{
    name	parameters
    label	"Moonray"
    group {
        name    "folder"
        label   "Frame"

        parm {
            name    "xn__moonraysceneVariablemin_frame_control_d1bn"
            label   "moonray:sceneVariable:min_frame"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablemin_frame_cobn"
            label   "Min Frame"
            type    float
            default { "0" }
            help    "Used to provide unique samples per frame."
            disablewhen "{ xn__moonraysceneVariablemin_frame_control_d1bn == block } { xn__moonraysceneVariablemin_frame_control_d1bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_frame_control_d1bn"
            label   "moonray:sceneVariable:max_frame"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablemax_frame_cobn"
            label   "Max Frame"
            type    float
            default { "0" }
            help    "Used to provide unique samples per frame."
            disablewhen "{ xn__moonraysceneVariablemax_frame_control_d1bn == block } { xn__moonraysceneVariablemax_frame_control_d1bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariableframe_control_uubn"
            label   "moonray:sceneVariable:frame"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableframe_thbn"
            label   "Frame"
            type    float
            default { "0" }
            help    "Used to provide unique samples per frame, and for selecting the frame for scenes with animated data."
            disablewhen "{ xn__moonraysceneVariableframe_control_uubn == block } { xn__moonraysceneVariableframe_control_uubn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
    }

    group {
        name    "folder2"
        label   "Camera and Layer"

        parm {
            name    "xn__moonraysceneVariablecamera_control_hwbn"
            label   "moonray:sceneVariable:camera"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablecamera_gjbn"
            label   "Camera"
            type    oppath
            default { "" }
            help    "This specifies the camera object used for rendering. If no camera is specified in the scene variables, MoonRay will render using the first camera object encountered."
            disablewhen "{ xn__moonraysceneVariablecamera_control_hwbn == block } { xn__moonraysceneVariablecamera_control_hwbn == none }"
            parmtag { "oprelative" "." }
            parmtag { "usdvaluetype" "<class 'pxr.Usd.Relationship'>" }
        }
        parm {
            name    "xn__moonraysceneVariabledicing_camera_control_v7bn"
            label   "moonray:sceneVariable:dicing_camera"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariabledicing_camera_uubn"
            label   "Dicing Camera"
            type    oppath
            default { "" }
            help    "This attribute specifies a camera to use for adaptive geometry tessellation. The rendering camera is used if no camera is specified."
            disablewhen "{ xn__moonraysceneVariabledicing_camera_control_v7bn == block } { xn__moonraysceneVariabledicing_camera_control_v7bn == none }"
            parmtag { "oprelative" "." }
            parmtag { "usdvaluetype" "<class 'pxr.Usd.Relationship'>" }
        }
        parm {
            name    "xn__moonraysceneVariablelayer_control_uubn"
            label   "moonray:sceneVariable:layer"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablelayer_thbn"
            label   "Layer"
            type    oppath
            default { "" }
            help    "This specifies the layer object used for rendering. If no layer is specified in the scene variables, MoonRay will rendering using the first layer object encountered."
            disablewhen "{ xn__moonraysceneVariablelayer_control_uubn == block } { xn__moonraysceneVariablelayer_control_uubn == none }"
            parmtag { "oprelative" "." }
            parmtag { "usdvaluetype" "<class 'pxr.Usd.Relationship'>" }
        }
    }

    group {
        name    "folder3"
        label   "Metadata"

        parm {
            name    "xn__moonraysceneVariableexr_header_attributes_control_wlcn"
            label   "moonray:sceneVariable:exr_header_attributes"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableexr_header_attributes_v7bn"
            label   "Exr Header Attributes"
            type    oppath
            default { "" }
            help    "Metadata that is passed directly to the exr header. Format: {\"name\", \"type\", \"value\"}"
            disablewhen "{ xn__moonraysceneVariableexr_header_attributes_control_wlcn == block } { xn__moonraysceneVariableexr_header_attributes_control_wlcn == none }"
            parmtag { "oprelative" "." }
            parmtag { "usdvaluetype" "<class 'pxr.Usd.Relationship'>" }
        }
    }

    group {
        name    "folder4"
        label   "Image Size"

        parm {
            name    "xn__moonraysceneVariableimage_width_control_m4bn"
            label   "moonray:sceneVariable:image_width"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableimage_width_lrbn"
            label   "Image Width"
            type    integer
            default { "1920" }
            help    "The desired width of the output image(s), in pixels."
            disablewhen "{ xn__moonraysceneVariableimage_width_control_m4bn == block } { xn__moonraysceneVariableimage_width_control_m4bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariableimage_height_control_85bn"
            label   "moonray:sceneVariable:image_height"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableimage_height_7sbn"
            label   "Image Height"
            type    integer
            default { "1080" }
            help    "The desired height of the output image(s), in pixels."
            disablewhen "{ xn__moonraysceneVariableimage_height_control_85bn == block } { xn__moonraysceneVariableimage_height_control_85bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariableres_control_lrbn"
            label   "moonray:sceneVariable:res"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableres_kebn"
            label   "Res"
            type    float
            default { "1" }
            help    "Final divisor for the overall image dimensions. A quick way to reduce or increase the size of the render. A value of 2 halves the size of the rendered image(s). A value of 0.5 doubles it."
            disablewhen "{ xn__moonraysceneVariableres_control_lrbn == block } { xn__moonraysceneVariableres_control_lrbn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__moonraysceneVariableaperture_window_control_4bcn"
            label   "moonray:sceneVariable:aperture_window"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        multiparm {
            name    "aperture_window"
            label    "Aperture Window"
            default 4
            disablewhen "{ xn__moonraysceneVariableaperture_window_control_4bcn == block } { xn__moonraysceneVariableaperture_window_control_4bcn == none }"
            parmtag { "usdvaluetype" "int[]" }

            parm {
                name    "xn__moonraysceneVariableaperture_window_3xbn#"
                label   "Aperture Window"
                type    integer
                default { "-2.14748e+09" }
                help    "Assuming no region_window is defined, an aperture_window of {xmin, ymin, xmax, ymax} overrides image_width using (xmax-xmin) and image_height using (ymax-ymin). Since the values are overrides, they are not restricted to lie in the ranges established by image_width and image_height, but can be arbitrarily large and/or negative. The lower left corner of the image rectangle corresponds to (xmin, ymin) and its midpoint corresponds to the camera's facing direction (the negative camera z-axis), and for projective cameras each boundary edge of the rectangle corresponds to a plane of the view frustum. However, the behavior changes when a region_window is defined - see the region_window documentation."
                range   { 0 10 }
                parmtag { "moonray::is_parm" "1" }
            }
        }

        parm {
            name    "xn__moonraysceneVariableregion_window_control_v7bn"
            label   "moonray:sceneVariable:region_window"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        multiparm {
            name    "region_window"
            label    "Region Window"
            default 4
            disablewhen "{ xn__moonraysceneVariableregion_window_control_v7bn == block } { xn__moonraysceneVariableregion_window_control_v7bn == none }"
            parmtag { "usdvaluetype" "int[]" }

            parm {
                name    "xn__moonraysceneVariableregion_window_uubn#"
                label   "Region Window"
                type    integer
                default { "-2.14748e+09" }
                help    "A region_window of {xmin, ymin, xmax, ymax} overrides the aperture_window if defined, and overrides image_width and image_height otherwise, to establish an image rectangle (xmax-xmin) in width and (ymax-ymin) in height, whose lower left corner corresponds to (xmin, ymin). Importantly, the coordinates are expressed relative to the origin of the aperture_window, or if aperture_window is not defined, relative to the lower-left corner of the image rectangle which would be obtained in the absence of a region_window. The region_window is not restricted to a subset of the aperture_window but can extend outside it, including asymmetrically. The view frustum is reshaped to correspond to the boundary of the region_window, and may therefore end up being skewed."
                range   { 0 10 }
                parmtag { "moonray::is_parm" "1" }
            }
        }

        parm {
            name    "xn__moonraysceneVariablesub_viewport_control_85bn"
            label   "moonray:sceneVariable:sub_viewport"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        multiparm {
            name    "sub_viewport"
            label    "Sub Viewport"
            default 4
            disablewhen "{ xn__moonraysceneVariablesub_viewport_control_85bn == block } { xn__moonraysceneVariablesub_viewport_control_85bn == none }"
            parmtag { "usdvaluetype" "int[]" }

            parm {
                name    "xn__moonraysceneVariablesub_viewport_7sbn#"
                label   "Sub Viewport"
                type    integer
                default { "-2.14748e+09" }
                help    "A sub_viewport of {xmin, ymin, xmax, ymax} restricts the rendered pixels to the rectangle defined by xmin <= x < xmax, ymin <= y < ymax, with origin at the lower left of the image rectangle - no matter how this has been defined (i.e. regardless of which combination of image_width, image_height, aperture_window, region_window has been used). Pixels outside the sub_viewport are left black. Any part of the sub_viewport lying outside the image rectangle has no effect on the result, since there are no pixels there."
                range   { 0 10 }
                parmtag { "moonray::is_parm" "1" }
            }
        }

    }

    group {
        name    "folder5"
        label   "Motion and Scale"

        parm {
            name    "xn__moonraysceneVariablemotion_steps_control_85bn"
            label   "moonray:sceneVariable:motion_steps"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        multiparm {
            name    "motion_steps"
            label    "Motion Steps"
            default 2
            disablewhen "{ xn__moonraysceneVariablemotion_steps_control_85bn == block } { xn__moonraysceneVariablemotion_steps_control_85bn == none }"
            parmtag { "usdvaluetype" "float[]" }

            parm {
                name    "xn__moonraysceneVariablemotion_steps_7sbn#"
                label   "Motion Steps"
                type    float
                default { "-1" }
                help    "Frame-relative time offsets for motion sampling"
                range   { 0 10 }
                parmtag { "moonray::is_parm" "1" }
            }
        }

        parm {
            name    "xn__moonraysceneVariableslerp_xforms_control_85bn"
            label   "moonray:sceneVariable:slerp_xforms"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariableslerp_xforms_7sbn"
            label   "Slerp Xforms"
            type    toggle
            default { "0" }
            help    "If use_rotation_motion_blur is false this will use slerp to interpolate the node_xform for motion blur"
            disablewhen "{ xn__moonraysceneVariableslerp_xforms_control_85bn == block } { xn__moonraysceneVariableslerp_xforms_control_85bn == none }"
            parmtag { "usdvaluetype" "bool" }
        }
        parm {
            name    "xn__moonraysceneVariablescene_scale_control_m4bn"
            label   "moonray:sceneVariable:scene_scale"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablescene_scale_lrbn"
            label   "Scene Scale"
            type    float
            default { "0.01" }
            help    "(in meters): one unit in world space = 'scene scale' meters"
            disablewhen "{ xn__moonraysceneVariablescene_scale_control_m4bn == block } { xn__moonraysceneVariablescene_scale_control_m4bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "float" }
        }
    }

    group {
        name    "folder6"
        label   "Sampling"

        parm {
            name    "xn__moonraysceneVariablepixel_samples_control_v7bn"
            label   "moonray:sceneVariable:pixel_samples"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablepixel_samples_uubn"
            label   "Pixel Samples"
            type    integer
            default { "8" }
            help    "The square root of the number of primary samples taken for each pixel in uniform sampling mode. For example, a value of 4 will result in 4*4 = 16 uniform pixel samples."
            disablewhen "{ xn__moonraysceneVariablepixel_samples_control_v7bn == block } { xn__moonraysceneVariablepixel_samples_control_v7bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablelight_samples_control_v7bn"
            label   "moonray:sceneVariable:light_samples"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablelight_samples_uubn"
            label   "Light Samples"
            type    integer
            default { "2" }
            help    "The square root of the number of samples taken for each light on the primary intersection."
            disablewhen "{ xn__moonraysceneVariablelight_samples_control_v7bn == block } { xn__moonraysceneVariablelight_samples_control_v7bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablebsdf_samples_control_85bn"
            label   "moonray:sceneVariable:bsdf_samples"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
                "setexisting"   "![BUTTONS_set_if_exists]Set if Exists"
                "add"           "![BUTTONS_set_add]Add if Exists"
                "multiply"      "![BUTTONS_set_multiply]Multiply if Exists"
                "block"         "![BUTTONS_set_block]Block"
                "none"          "![BUTTONS_set_nothing]Do Nothing"
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__moonraysceneVariablebsdf_samples_7sbn"
            label   "Bsdf Samples"
            type    integer
            default { "2" }
            help    "The square root of the number of samples taken for BSDF lobe evaluations on the primary intersection. The number of samples taken per material depends on the BSDF sampler strategy and the number of lobes that comprise the material."
            disablewhen "{ xn__moonraysceneVariablebsdf_samples_control_85bn == block } { xn__moonraysceneVariablebsdf_samples_control_85bn == none }"
            range   { 0 10 }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "xn__moonraysceneVariablebssrdf_samples_control_i9bn"
            label   "moonray:sceneVariable:bssrdf_samples"
            type    string
            default { "none" }
            menujoin {
                "set"           "![BUTTONS_set_or_create]Set or Create"
